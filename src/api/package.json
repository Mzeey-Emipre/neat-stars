{
  "name": "@neat-stars/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 execute neat-stars-db --local --file=src/db/schema.sql",
    "db:migrate:remote": "wrangler d1 execute neat-stars-db --remote --file=src/db/schema.sql",
    "seed:generate": "bun run src/db/seed.ts > src/db/seed.sql",
    "seed:local": "bun run seed:generate && wrangler d1 execute neat-stars-db --local --file=src/db/seed.sql"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
